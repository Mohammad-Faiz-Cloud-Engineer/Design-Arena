{
  "manifest_version": 3,
  "name": "Design Arena",
  "version": "1.4.0",
  "description": "Build projects with AI using prompts. Design Arena in your browser's side panel - select any text and send it directly to start creating.",
  "author": "Mohammad Faiz",
  "icons": {
    "16": "icons/png/icon16.png",
    "32": "icons/png/icon32.png",
    "48": "icons/png/icon48.png",
    "128": "icons/png/icon128.png"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "declarativeNetRequest",
    "contextMenus",
    "downloads",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://designarena.ai/*",
    "https://*.designarena.ai/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["https://designarena.ai/*", "https://*.designarena.ai/*"],
      "js": ["content/content-script.js"],
      "css": ["content/content-style.css"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "arena_headers_ruleset",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "Open Design Arena"
  },
  "minimum_chrome_version": "114"
}
